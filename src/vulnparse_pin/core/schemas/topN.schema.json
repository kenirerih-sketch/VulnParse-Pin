{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://vulnparse-pin.com/schemas/topN.schema.json",
    "title": "VulnParse-Pin TopN Configuration Schema",
    "description": "Schema for TopN ranking and exposure inferernce rule configuration. Structural validation only",
    "type": "object",
    "additionalProperties": false,
    "required": ["topn", "inference"],
    "properties": {
        "meta": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "name": { "type": "string", "minLength": 1, "maxLength": 128},
                "version": { "type": "string", "minLength": 1, "maxLength": 32},
                "notes": { "type": "string", "maxLength": 4096}
            }
        },

        "topn": {
            "type": "object",
            "additionalProperties": false,
            "required": ["rank_basis", "decay"],
            "properties": {
                "rank_basis": {
                    "type": "string",
                    "enum": ["raw", "operational"],
                    "description": "Score basis used for ranking. Default is raw (engine canonical)."
                },

                "decay": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 25,
                    "items": {
                        "type": "number",
                        "minimum": 0.0,
                        "maximum": 1.0
                    },
                    "description": "Top-K decay weights for aggregating top findings per asset. K is defined as len(decay)."
                },

                "max_assets": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 500,
                    "default": 25,
                    "description": "Max number of ranked assets to emit."
                },

                "max_findings_per_asset": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 500,
                    "default": 10,
                    "description": "Max number of ranked findings to emit per ranked asset."
                },

                "include_global_top_findings": {
                    "type": "boolean",
                    "default": true,
                    "description": "Whether to emit a global Top-N findings list in TopNPass output."
                },

                "global_top_findings_max": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 1000,
                    "default": 50,
                    "description": "Max number of findings to emit in the global Top-N findings list."
                }
            }
        },

        "inference": {
            "type": "object",
            "additionalProperties": false,
            "required": ["confidence_thresholds", "public_service_ports", "rules"],
            "properties": {
                "confidence_thresholds": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["low", "medium", "high"],
                    "properties": {
                        "low": { "type": "integer", "minimum": -100, "maximum": 100 },
                        "medium": { "type": "integer", "minimum": -100, "maximum": 100 },
                        "high": { "type": "integer", "minimum": -100, "maximum": 100 }
                    },
                    "description": "Exposure score thresholds used to bucket confidence. Validation enforces low < medium < high."
                },

                "public_service_ports": {
                    "type": "array",
                    "minItems": 0,
                    "maxItems": 2000,
                    "uniqueItems": true,
                    "items": { "type": "integer", "minimum": 1, "maximum": 65535 },
                    "description": "Ports treated as common public-service ports for inference signals."
                },

                "allow_predicates": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 50,
                    "uniqueItems": true,
                    "items": { "type": "string", "minLength": 1, "maxLength": 64 },
                    "default": [
                        "ip_is_public",
                        "ip_is_private",
                        "any_port_in_public_list",
                        "port_in",
                        "hostname_contains_any",
                        "finding_text_contains_any",
                        "criticality_is"
                    ],
                    "description": "Allowlist of supported predicate names (including optional criticality-based predicates)."
                },

                "finding_text_min_token_matches": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 10,
                    "default": 2,
                    "description": "Minimum distinct token matches required for finding_text_contains_any to trigger."
                },

                "finding_text_title_weight": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 10,
                    "default": 3,
                    "description": "Source quality weight multiplier applied to title token hits."
                },

                "finding_text_description_weight": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 10,
                    "default": 2,
                    "description": "Source quality weight multiplier applied to description token hits."
                },

                "finding_text_plugin_output_weight": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 10,
                    "default": 1,
                    "description": "Source quality weight multiplier applied to plugin-output token hits."
                },

                "finding_text_max_weighted_hits": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 50,
                    "default": 4,
                    "description": "Upper cap for weighted text evidence accumulation (bounded monotonicity)."
                },

                "finding_text_conflict_tokens": {
                    "type": "array",
                    "minItems": 0,
                    "maxItems": 50,
                    "items": { "type": "string", "minLength": 1, "maxLength": 64 },
                    "default": [],
                    "description": "Negative lexical constraints that reduce finding-text inferred weight when present."
                },

                "finding_text_conflict_penalty": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 10,
                    "default": 2,
                    "description": "Penalty per matched conflict token applied to weighted finding-text evidence."
                },

                "finding_text_diminishing_factors": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 10,
                    "items": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
                    "default": [1.0, 0.6, 0.4],
                    "description": "Diminishing-return factors applied per incremental weighted finding-text hit."
                },

                "rules": {
                    "type": "array",
                    "minItems": 0,
                    "maxItems": 500,
                    "items": { "$ref": "#/$defs/InferenceRule" }
                }
            }
        },

        "triage_policy": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "enabled": {
                    "type": "boolean",
                    "default": true
                },
                "oal1_risk_bands": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 5,
                    "uniqueItems": true,
                    "items": { "type": "string", "enum": ["critical", "high", "medium", "low", "informational"] },
                    "default": ["critical", "high"]
                },
                "oal1_require_public_exposure": {
                    "type": "boolean",
                    "default": true
                },
                "oal1_require_exploit_or_kev": {
                    "type": "boolean",
                    "default": true
                },
                "oal2_risk_bands": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 5,
                    "uniqueItems": true,
                    "items": { "type": "string", "enum": ["critical", "high", "medium", "low", "informational"] },
                    "default": ["critical", "high", "medium"]
                },
                "oal2_min_aci_confidence": {
                    "type": "number",
                    "minimum": 0.0,
                    "maximum": 1.0,
                    "default": 0.8
                },
                "oal2_require_chain_candidate": {
                    "type": "boolean",
                    "default": true
                },
                "oal2_require_public_exposure": {
                    "type": "boolean",
                    "default": true
                },
                "preserve_oal1_precedence": {
                    "type": "boolean",
                    "default": true
                },
                "p1_risk_bands": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 5,
                    "uniqueItems": true,
                    "items": { "type": "string", "enum": ["critical", "high", "medium", "low", "informational"] },
                    "default": ["critical", "high"]
                },
                "p1_require_public_exposure": {
                    "type": "boolean",
                    "default": true
                },
                "p1_require_exploit_or_kev": {
                    "type": "boolean",
                    "default": true
                },
                "p1b_risk_bands": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 5,
                    "uniqueItems": true,
                    "items": { "type": "string", "enum": ["critical", "high", "medium", "low", "informational"] },
                    "default": ["critical", "high", "medium"]
                },
                "p1b_min_aci_confidence": {
                    "type": "number",
                    "minimum": 0.0,
                    "maximum": 1.0,
                    "default": 0.8
                },
                "p1b_require_chain_candidate": {
                    "type": "boolean",
                    "default": true
                },
                "p1b_require_public_exposure": {
                    "type": "boolean",
                    "default": true
                },
                "preserve_p1_precedence": {
                    "type": "boolean",
                    "default": true
                }
            }
        },

        "aci": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "enabled": {
                    "type": "boolean",
                    "default": false,
                    "description": "Enable Attack Capability Inference derived pass influence for TopN ranking tie-break keys."
                },
                "min_confidence": {
                    "type": "number",
                    "minimum": 0.0,
                    "maximum": 1.0,
                    "default": 0.6,
                    "description": "Minimum ACI confidence required before any ranking uplift can apply."
                },
                "max_uplift": {
                    "type": "number",
                    "minimum": 0.0,
                    "maximum": 10.0,
                    "default": 2.0,
                    "description": "Maximum finding-level ranking uplift used only as TopN tie-break signal."
                },
                "asset_uplift_weight": {
                    "type": "number",
                    "minimum": 0.0,
                    "maximum": 1.0,
                    "default": 0.5,
                    "description": "Weight applied when aggregating finding-level ACI uplift into asset-level TopN tie-break signal."
                },
                "token_mode": {
                    "type": "string",
                    "enum": ["merge", "replace"],
                    "default": "merge",
                    "description": "Token vocabulary mode: merge user aliases with maintained core tokens or replace core tokens entirely."
                },
                "signal_aliases": {
                    "type": "array",
                    "minItems": 0,
                    "maxItems": 200,
                    "items": {
                        "type": "object",
                        "additionalProperties": false,
                        "required": ["token", "signal"],
                        "properties": {
                            "token": { "type": "string", "minLength": 1, "maxLength": 64 },
                            "signal": { "type": "string", "minLength": 1, "maxLength": 64 }
                        }
                    }
                },
                "disabled_core_tokens": {
                    "type": "array",
                    "minItems": 0,
                    "maxItems": 200,
                    "items": { "type": "string", "minLength": 1, "maxLength": 64 }
                },
                "exploit_boost": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "enabled": {
                            "type": "boolean",
                            "default": true
                        },
                        "weight": {
                            "type": "number",
                            "minimum": 0.0,
                            "maximum": 1.0,
                            "default": 0.25
                        },
                        "max_bonus": {
                            "type": "number",
                            "minimum": 0.0,
                            "maximum": 0.5,
                            "default": 0.2
                        }
                    }
                },
                "capability_rules": {
                    "type": "array",
                    "minItems": 0,
                    "maxItems": 200,
                    "items": {
                        "type": "object",
                        "additionalProperties": false,
                        "required": ["id", "capability", "signals", "weight"],
                        "properties": {
                            "id": { "type": "string", "pattern": "^[a-z0-9_\\-]{1,64}$" },
                            "enabled": { "type": "boolean", "default": true },
                            "capability": { "type": "string", "minLength": 1, "maxLength": 64 },
                            "signals": {
                                "type": "array",
                                "minItems": 1,
                                "maxItems": 10,
                                "items": { "type": "string", "minLength": 1, "maxLength": 64 }
                            },
                            "weight": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
                        }
                    }
                },
                "chain_rules": {
                    "type": "array",
                    "minItems": 0,
                    "maxItems": 100,
                    "items": {
                        "type": "object",
                        "additionalProperties": false,
                        "required": ["id", "requires_all", "label"],
                        "properties": {
                            "id": { "type": "string", "pattern": "^[a-z0-9_\\-]{1,64}$" },
                            "enabled": { "type": "boolean", "default": true },
                            "requires_all": {
                                "type": "array",
                                "minItems": 1,
                                "maxItems": 10,
                                "items": { "type": "string", "minLength": 1, "maxLength": 64 }
                            },
                            "label": { "type": "string", "minLength": 1, "maxLength": 128 }
                        }
                    }
                }
            }
        }
    },

    "$defs": {
        "InferenceTag": {
            "type": "string",
            "enum": ["externally_facing", "public_service_ports"],
            "description": "Derived-only inference tags. These do not claim certainty"
        },

        "InferenceRule": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "when", "weight", "tag"],
            "properties": {
                "id": {
                    "type": "string",
                    "pattern": "^[a-z0-9_\\-]{1,64}$",
                    "description": "Rule identifier (stable)."
                },

                "enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Whether the rule is active."
                },

                "tag": { "$ref": "#/$defs/InferenceTag" },

                "weight": {
                    "type": "integer",
                    "minimum": -50,
                    "maximum": 50,
                    "description": "Signed integer score contribution when predicate matches."
                },

                "when": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 256,
                    "description": "Predicate expression. Supported forms include ip_is_public, ip_is_private, any_port_in_public_list, port_in:[...], hostname_contains_any:[...], finding_text_contains_any:[...], criticality_is:[extreme|high|medium|low]."
                },

                "evidence": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 256,
                    "description": "Optional evidence message template. If omitted, engine generates a default evidence string."
                }
            }
        }
    }
}

