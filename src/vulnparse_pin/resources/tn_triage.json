{
    "meta": {
        "name": "VulnParse-Pin TopN Triage Config",
        "version": "1",
        "notes": "Token-based inference rules. Ranking uses raw score by default. K = len(topn.decay)."
    },
    "topn": {
        "rank_basis": "raw",
        "decay": [1.0, 0.7, 0.5, 0.35, 0.25],
        "max_assets": 25,
        "max_findings_per_asset": 10,
        "include_global_top_findings": true,
        "global_top_findings_max": 50
    },
    "inference": {
        "confidence_thresholds": {
            "low": 2,
            "medium": 5,
            "high": 8
        },
        "public_service_ports": [
            7, 8, 13, 17, 18,
            20, 21, 22, 23, 25,
            53, 69,
            80, 81, 88,
            110, 111, 115, 119,
            123,
            135, 137, 138, 139,
            143, 161, 162,
            389, 443, 445,
            465, 514, 587,
            636,
            873,
            993, 995,
            1433, 1521,
            2049, 2375, 2376,
            3306, 3389,
            5432,
            5900,
            5985, 5986,
            6379,
            8080, 8081, 8443,
            9200,
            11211,
            27017
        ],
        "allow_predicates": [
            "ip_is_public",
            "ip_is_private",
            "ip_is_private_no_public_ports",
            "any_port_in_public_list",
            "port_in",
            "hostname_contains_any",
            "finding_text_contains_any",
            "criticality_is"
        ],
        "finding_text_min_token_matches": 2,
        "finding_text_title_weight": 3,
        "finding_text_description_weight": 2,
        "finding_text_plugin_output_weight": 1,
        "finding_text_max_weighted_hits": 4,
        "finding_text_conflict_tokens": [
            "internal only",
            "localhost",
            "loopback",
            "not externally accessible",
            "not internet accessible"
        ],
        "finding_text_conflict_penalty": 2,
        "finding_text_diminishing_factors": [1.0, 0.6, 0.4],
        "rules": [
            {
                "id": "public_ip",
                "enabled": true,
                "tag": "externally_facing",
                "weight": 6,
                "when": "ip_is_public",
                "evidence": "Public IP address observed (+6)"
            },
            {
                "id": "private_ip",
                "enabled": true,
                "tag": "externally_facing",
                "weight": -3,
                "when": "ip_is_private",
                "evidence": "RFC1918/private IP observed (-3)"
            },
            {
                "id": "private_ip_no_public_ports",
                "enabled": true,
                "tag": "externally_facing",
                "weight": -4,
                "when": "ip_is_private_no_public_ports",
                "evidence": "Private IP with no internet-service ports - likely internal-only (-4)"
            },
            {
                "id": "public_service_port_hit",
                "enabled": true,
                "tag": "public_service_ports",
                "weight": 2,
                "when": "any_port_in_public_list",
                "evidence": "Common public-service port observed (+2)"
            },
            {
                "id": "edge_hostname_hint",
                "enabled": true,
                "tag": "externally_facing",
                "weight": 1,
                "when": "hostname_contains_any:[dmz,edge,gw,gateway,bastion,vpn,proxy,lb,loadbalancer,public]",
                "evidence": "Hostname hint suggests edge exposure (+1)"
            },
            {
                "id": "finding_text_exposure_hint",
                "enabled": true,
                "tag": "externally_facing",
                "weight": 4,
                "when": "finding_text_contains_any:[internet,public,externally,exposed,remote service,open port,accessible from network]",
                "evidence": "Finding text suggests network exposure (+4)"
            },
            {
                "id": "critical_asset_hint",
                "enabled": true,
                "tag": "externally_facing",
                "weight": 1,
                "when": "criticality_is:[extreme,high]",
                "evidence": "Asset criticality suggests elevated exposure priority (+1)"
            }
        ]
    },
    "triage_policy": {
        "enabled": true,
        "oal1_risk_bands": ["critical", "high"],
        "oal1_require_public_exposure": true,
        "oal1_require_exploit_or_kev": true,
        "oal2_risk_bands": ["critical", "high", "medium"],
        "oal2_min_aci_confidence": 0.8,
        "oal2_require_chain_candidate": true,
        "oal2_require_public_exposure": true,
        "preserve_oal1_precedence": true
    },
    "aci": {
        "enabled": false,
        "min_confidence": 0.6,
        "max_uplift": 2.0,
        "asset_uplift_weight": 0.5,
        "token_mode": "merge",
        "signal_aliases": [],
        "disabled_core_tokens": [],
        "exploit_boost": {
            "enabled": true,
            "weight": 0.25,
            "max_bonus": 0.2
        },
        "capability_rules": [
            {
                "id": "cap_initial_access",
                "enabled": true,
                "capability": "initial_access",
                "signals": ["exploit", "remote_service", "rce", "lfi", "sqli", "auth bypass"],
                "weight": 0.7
            },
            {
                "id": "cap_remote_execution",
                "enabled": true,
                "capability": "remote_execution",
                "signals": ["exploit", "remote_service", "rce"],
                "weight": 0.85
            },
            {
                "id": "cap_privilege_escalation",
                "enabled": true,
                "capability": "privilege_escalation",
                "signals": ["privesc", "privilege escalation", "sudo", "setuid", "kernel"],
                "weight": 0.75
            },
            {
                "id": "cap_credential_access",
                "enabled": true,
                "capability": "credential_access",
                "signals": ["credential", "password", "hash"],
                "weight": 0.65
            },
            {
                "id": "cap_information_disclosure",
                "enabled": true,
                "capability": "information_disclosure",
                "signals": ["info disclosure", "information disclosure", "sensitive data", "leak", "exposure"],
                "weight": 0.55
            },
            {
                "id": "cap_persistence",
                "enabled": true,
                "capability": "persistence",
                "signals": ["persistence", "startup", "autorun", "scheduled task", "service install"],
                "weight": 0.6
            },
            {
                "id": "cap_local_file_inclusion",
                "enabled": true,
                "capability": "local_file_inclusion",
                "signals": ["lfi", "local file inclusion", "path traversal", "file read", "etc/passwd"],
                "weight": 0.7
            },
            {
                "id": "cap_sql_injection",
                "enabled": true,
                "capability": "sql_injection",
                "signals": ["sqli", "sql injection", "union select", "database", "query"],
                "weight": 0.72
            },
            {
                "id": "cap_auth_bypass",
                "enabled": true,
                "capability": "auth_bypass",
                "signals": ["auth bypass", "authentication bypass", "bypass login", "default credential"],
                "weight": 0.68
            },
            {
                "id": "cap_command_execution",
                "enabled": true,
                "capability": "command_execution",
                "signals": ["command injection", "cmd injection", "os command", "command execution"],
                "weight": 0.78
            },
            {
                "id": "cap_secrets_exposure",
                "enabled": true,
                "capability": "secrets_exposure",
                "signals": ["api key", "token", "secret", "private key", "hardcoded credential"],
                "weight": 0.62
            },
            {
                "id": "cap_lateral_movement",
                "enabled": true,
                "capability": "lateral_movement",
                "signals": ["smb", "ssh", "rdp", "rpc"],
                "weight": 0.6
            }
        ],
        "chain_rules": [
            {
                "id": "chain_initial_to_credential",
                "enabled": true,
                "requires_all": ["remote_execution", "credential_access"],
                "label": "Initial access and credential theft pathway"
            },
            {
                "id": "chain_credential_to_lateral",
                "enabled": true,
                "requires_all": ["credential_access", "lateral_movement"],
                "label": "Credential-assisted lateral movement pathway"
            },
            {
                "id": "chain_initial_to_privesc",
                "enabled": true,
                "requires_all": ["remote_execution", "privilege_escalation"],
                "label": "Initial access to privilege escalation pathway"
            },
            {
                "id": "chain_sqli_to_disclosure",
                "enabled": true,
                "requires_all": ["sql_injection", "information_disclosure"],
                "label": "Database exploitation and information disclosure pathway"
            },
            {
                "id": "chain_lfi_to_persistence",
                "enabled": true,
                "requires_all": ["local_file_inclusion", "persistence"],
                "label": "File inclusion to persistence pathway"
            },
            {
                "id": "chain_lfi_to_disclosure",
                "enabled": true,
                "requires_all": ["local_file_inclusion", "information_disclosure"],
                "label": "File inclusion to information disclosure pathway"
            },
            {
                "id": "chain_lfi_to_credential",
                "enabled": true,
                "requires_all": ["local_file_inclusion", "credential_access"],
                "label": "File inclusion to credential access pathway"
            },
            {
                "id": "chain_privesc_to_persistence",
                "enabled": true,
                "requires_all": ["privilege_escalation", "persistence"],
                "label": "Privilege escalation to persistence pathway"
            },
            {
                "id": "chain_initial_access_to_credential",
                "enabled": true,
                "requires_all": ["initial_access", "credential_access"],
                "label": "Initial access to credential access pathway"
            },
            {
                "id": "chain_auth_bypass_to_initial_access",
                "enabled": true,
                "requires_all": ["auth_bypass", "initial_access"],
                "label": "Authentication bypass to initial access pathway"
            },
            {
                "id": "chain_command_exec_to_privesc",
                "enabled": true,
                "requires_all": ["command_execution", "privilege_escalation"],
                "label": "Command execution to privilege escalation pathway"
            },
            {
                "id": "chain_disclosure_to_credential",
                "enabled": true,
                "requires_all": ["information_disclosure", "credential_access"],
                "label": "Information disclosure to credential access pathway"
            },
            {
                "id": "chain_sqli_to_credential",
                "enabled": true,
                "requires_all": ["sql_injection", "credential_access"],
                "label": "SQL injection to credential access pathway"
            },
            {
                "id": "chain_secrets_to_credential",
                "enabled": true,
                "requires_all": ["secrets_exposure", "credential_access"],
                "label": "Secrets exposure to credential access pathway"
            }
        ]
    }
}